# ═══════════════════════════════════════════
# PV-OpsHub — Environment Variables
# Copy to .env.local and fill in real values
# ═══════════════════════════════════════════

# ─── Database ─────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pvopshub?schema=public"
# Direct connection for migrations (bypasses pgBouncer if in use)
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pvopshub?schema=public"

# ─── Authentication ──────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-64-char-random-string-in-production"
# Session max age in seconds (default: 8 hours)
SESSION_MAX_AGE=28800

# ─── Redis / Cache ───────────────────────
REDIS_URL="redis://:redis_password@localhost:6379"
REDIS_PASSWORD="redis_password"
# Upstash (for rate limiting in Edge Runtime)
UPSTASH_REDIS_REST_URL="https://your-upstash-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-rest-token"

# ─── Real-time (Pusher) ─────────────────
# Use PUSHER_APP_ID=local-dev to disable real-time (app falls back to polling)
PUSHER_APP_ID="your-app-id"
PUSHER_KEY="your-pusher-key"
PUSHER_SECRET="your-pusher-secret"
PUSHER_CLUSTER="ap2"
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="ap2"

# ─── Email (Resend) ─────────────────────
# Use re_placeholder_* to skip sending (logs to console in dev)
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM="PV-OpsHub <notifications@yourdomain.com>"
EMAIL_FROM="PV-OpsHub <notifications@yourdomain.com>"

# ─── Encryption ──────────────────────────
# AES-256 key — MUST be exactly 32 bytes hex-encoded (64 chars)
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"
# Previous key for rotation (decrypt only — leave empty if no rotation)
ENCRYPTION_KEY_PREV=""

# ─── Monitoring ──────────────────────────
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
SENTRY_RELEASE=""
# Secret header value to access /api/metrics
METRICS_SECRET="change-me-metrics-secret"
# Log level: debug | info | warn | error
LOG_LEVEL="info"

# ─── Feature Flags ──────────────────────
ENABLE_PUSHER_REALTIME="true"
ENABLE_EMAIL_NOTIFICATIONS="false"
ENABLE_BACKGROUND_JOBS="true"

# ─── Application ─────────────────────────
NODE_ENV="development"
PORT=3000
APP_VERSION="1.0.0"
